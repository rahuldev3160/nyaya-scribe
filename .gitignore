# Copyrighted PDF source material and large binaries — never commit
pdfs/
sources/
data/audio/

# Large data files not needed for app runtime
data/upsc.db
data/rbi.db
data/answers_batch.txt

# Live DB — user data accumulates here; not committed (ies_seed.db is the committed clean copy)
data/ies.db

# SQLite WAL runtime files (generated at runtime, not committed)
data/ies.db-shm
data/ies.db-wal
data/rbi.db-shm
data/rbi.db-wal
data/upsc.db-shm
data/upsc.db-wal

# API batch job IDs
exports/answers_batch.txt
exports/prototype_diagrams.json

# Secrets
.env
.streamlit/credentials.toml

# Python artifacts
__pycache__/
*.pyc
*.pyo
.DS_Store
*.egg-info/
dist/
build/

# YouTube API credentials
config/youtube_client_secret.json
config/youtube_token.json
