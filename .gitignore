# Copyrighted PDF source material and large binaries — never commit
pdfs/
sources/
data/audio/

# Live DBs (user data accumulates; seed copies are committed instead)
data/ies.db
data/rbi.db
data/upsc.db
data/english.db
data/answers_batch.txt

# SQLite WAL runtime files (generated at runtime, never committed)
data/*.db-shm
data/*.db-wal

# API batch job IDs
exports/answers_batch.txt
exports/prototype_diagrams.json

# Secrets
.env
.secret_key
.streamlit/credentials.toml

# Python artifacts
__pycache__/
*.pyc
*.pyo
.DS_Store
*.egg-info/
dist/
build/

# YouTube API credentials
config/youtube_client_secret.json
config/youtube_token.json
